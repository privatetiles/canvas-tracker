    <div class="help-section">
      <div class="help-title">SHORTCUTS</div>
      <div class="help-row"><span class="help-cmd">TAB</span><span class="help-info">Autocomplete command</span></div>
      <div class="help-row"><span class="help-cmd">↑ / ↓</span><span class="help-info">Navigate command history</span></div>
    </div>
  `;
}

// ─── COMMAND REGISTRY ─────────────────────────────────────
function initCommands() {
  regCmd('help', ['?'], () => {
    switchTab('help');
    printBanner('COMMAND REFERENCE', 'cyan bold');
    Object.values(COMMANDS).filter((v,i,a) => a.indexOf(v) === i).forEach(c => {
      print('  <span class="t-text cyan">' + c.usage.padEnd(24) + '</span><span class="t-text gray">' + c.desc + '</span>');
    });
  }, 'Show all commands', 'help');

  regCmd('clear', ['cls'], () => clearTerminal(), 'Clear terminal', 'clear');

  regCmd('scan', [], () => {
    printBanner('◈ AVAILABLE TARGETS', 'cyan bold');
    TARGETS.forEach(t => {
      const locked = player.level < t.minLevel;
      const sel    = player.activeTarget === t.id;
      print(
        (sel ? '▶ ' : '  ') + t.icon + ' <span class="t-text ' + (locked ? 'red' : 'green') + '">' +
        t.name.padEnd(28) + '</span>' +
        '<span class="t-text gray">DEF:</span><span class="t-text red">' + String(t.defense + '%').padEnd(5) + '</span>' +
        '<span class="t-text gray">  ×' + t.mult + '</span>' +
        (locked ? '  <span class="t-text red">[LVL ' + t.minLevel + ' REQUIRED]</span>' : ''), ''
      );
    });
  }, 'List all targets', 'scan');

  regCmd('hacks', ['ls', 'list'], () => {
    printBanner('◈ HACK DICTIONARY', 'green bold');
    Object.values(HACKS).forEach(h => {
      const locked = player.level < h.levelReq;
      const sel    = player.activeHack === h.name;
      print(
        (sel ? '▶ ' : '  ') + '<span class="t-text ' + (locked ? 'red' : 'green') + '">' +
        h.name.padEnd(22) + '</span>' +
        '<span class="t-text gray">LVL ' + h.levelReq + '  SUC:' + h.successBase + '%  DET:' + h.detectRisk + '%</span>' +
        (locked ? '  <span class="t-text red">[LOCKED]</span>' : ''), ''
      );
    });
  }, 'List available hacks', 'hacks');

  regCmd('status', ['stats', 'whoami'], () => {
    printBanner('◈ OPERATIVE STATUS', 'magenta bold');
    print('Alias   : <span class="t-text magenta">' + player.name + '</span>');
    print('Level   : <span class="t-text green">' + player.level + ' — ' + getTitle() + '</span>');
    print('Credits : <span class="t-text yellow">' + player.credits + ' CR</span>');
    print('XP      : <span class="t-text cyan">' + player.xp + '</span>');
    print('Wins    : <span class="t-text green">' + player.wins + '</span>  Losses: <span class="t-text red">' + player.losses + '</span>  Detected: <span class="t-text red">' + player.detected + '</span>');
    const gear = Object.keys(player.upgrades).filter(k => player.upgrades[k]);
    print('Gear    : <span class="t-text cyan">' + (gear.length ? gear.join(', ') : 'None installed') + '</span>');
  }, 'Show player status', 'status');

  regCmd('use', [], (args) => {
    if (!args[0]) { print('Usage: use [hackname]', 'red'); return; }
    const key  = args[0].toUpperCase();
    const hack = HACKS[key];
    if (!hack) { print('Unknown hack: ' + args[0], 'red'); return; }
    if (player.level < hack.levelReq) { print('🔒 ' + hack.name + ' requires Level ' + hack.levelReq, 'red'); return; }
    player.activeHack = key;
    document.getElementById('inf-hack').textContent = hack.name;
    print('✓ Hack loaded: <span class="t-text cyan">' + hack.name + '</span>', 'green');
    print('  ' + hack.desc, 'gray');
    renderDictionary();
  }, 'Select a hack technique', 'use [hackname]');

  regCmd('attack', ['target'], (args) => {
    if (!args[0]) { print('Usage: attack [target]', 'red'); return; }
    const id = args[0].toLowerCase();
    const t  = TARGETS.find(x => x.id === id || x.name.toLowerCase().includes(id));
    if (!t) { print('Unknown target: ' + args[0] + '. Use <span class="t-text cyan">scan</span> to list targets.', 'red'); return; }
    if (player.level < t.minLevel) { print('🔒 ' + t.name + ' requires Level ' + t.minLevel, 'red'); return; }
    player.activeTarget = t.id;
    document.getElementById('inf-tname').textContent = t.name;
    document.getElementById('inf-tdef').textContent  = t.defense + '%';
    document.getElementById('inf-tmult').textContent = '×' + t.mult;
    renderTargetList();
    print('✓ Target locked: <span class="t-text cyan">' + t.icon + ' ' + t.name + '</span>', 'green');
    if (player.activeHack) print('  Type <span class="t-text cyan">run</span> to execute ' + player.activeHack, 'gray');
    else print('  Use <span class="t-text cyan">use [hackname]</span> to select a hack first.', 'gray');
  }, 'Lock onto a target', 'attack [target]');

  regCmd('run', ['exec', 'execute'], () => {
    if (!player.activeHack)   { print('No hack selected. Use <span class="t-text cyan">use [hackname]</span>', 'red'); return; }
    if (!player.activeTarget) { print('No target selected. Use <span class="t-text cyan">attack [target]</span>', 'red'); return; }
    startHack();
  }, 'Execute selected hack on selected target', 'run');

  regCmd('shop', [], () => {
    switchTab('shop');
    print('Opened shop. Use <span class="t-text cyan">buy [item]</span> to purchase.', 'gray');
  }, 'Open upgrade shop', 'shop');

  regCmd('buy', [], (args) => {
    if (!args[0]) { print('Usage: buy [item]', 'red'); return; }
    buyUpgrade(args[0].toUpperCase());
  }, 'Purchase an upgrade', 'buy [item]');
}

// ─── MODAL ────────────────────────────────────────────────
function showModal(title, body, withInput, callback) {
  const overlay = document.getElementById('modal-overlay');
  document.getElementById('modal-title').textContent = title;
  document.getElementById('modal-body').textContent  = body;
  const inputWrap = document.getElementById('modal-input-wrap');
  const btns      = document.getElementById('modal-buttons');
  const input     = document.getElementById('modal-input');
  btns.innerHTML  = '';

  if (withInput) {
    inputWrap.style.display = 'flex';
    input.value = '';
    input.placeholder = 'alias...';
    setTimeout(() => input.focus(), 100);
    const btn = document.createElement('button');
    btn.className   = 'modal-btn';
    btn.textContent = '[ CONFIRM ]';
    btn.onclick = () => { overlay.classList.remove('open'); if (callback) callback(input.value); };
    input.onkeydown = e => { if (e.key === 'Enter') btn.click(); };
    btns.appendChild(btn);
  } else {
    inputWrap.style.display = 'none';
    const btn = document.createElement('button');
    btn.className   = 'modal-btn';
    btn.textContent = '[ OK ]';
    btn.onclick = () => { overlay.classList.remove('open'); if (callback) callback(); };
    btns.appendChild(btn);
  }
  overlay.classList.add('open');
}

// ─── BOOT & START ─────────────────────────────────────────
function launchTerminal() {
  document.getElementById('boot-screen').style.display = 'none';
  document.getElementById('app').style.display         = 'grid';
  document.getElementById('footer').style.display      = 'flex';

  initTerminal();
  initCommands();
  initHelp();
  updateHUD();
  renderTargetList();
  switchTab('terminal');

  printBanner('TERMINAL BREACH v2.0 — GHOST PROTOCOL ACTIVE', 'green bold');
  print('Welcome, <span class="t-text magenta">' + player.name + '</span>. Ghost terminal initialized.');
  print('Type <span class="t-text cyan">help</span> for commands · <span class="t-text cyan">scan</span> for targets · <span class="t-text cyan">hacks</span> for techniques.', 'gray');
  printBlank();
  print('All operations are 100% fictional. This is a game.', 'gray');
  printBlank();

  setInterval(() => {
    document.getElementById('f-time').textContent =
      new Date().toLocaleTimeString('en-US', { hour12: false }) + ' UTC';
  }, 1000);

  document.getElementById('terminal-input').focus();
}

function startGame() {
  showModal('ENTER OPERATIVE ALIAS', 'Choose your hacker alias.', true, name => {
    player.name = (name || '').trim() || 'Ghost';
    launchTerminal();
  });
}

function runBoot() {
  const ids = ['b1','b2','b3','b4','b5','b6'];
  const bar = document.getElementById('boot-bar-fill');
  const pct = document.getElementById('boot-pct');
  ids.forEach((id, i) => {
    setTimeout(() => {
      const el = document.getElementById(id);
      el.style.animation = 'fadeIn 0.4s ease forwards';
      const p = Math.round(((i + 1) / ids.length) * 100);
      bar.style.width  = p + '%';
      pct.textContent  = p + '%';
      if (i === ids.length - 1) {
        setTimeout(() => { document.getElementById('start-btn').style.display = 'block'; }, 400);
      }
    }, i * 500 + 300);
  });
}

runBoot();

  printBlank();
}

function clearTerminal() {
  outputEl.innerHTML = '';
}

function typewritePrint(text, cls = '', delay = 20, prefix = '') {
  return new Promise(resolve => {
    const line = document.createElement('div');
    line.className = 't-line';

    if (prefix) {
      const pre = document.createElement('span');
      pre.className = 't-prefix';
      pre.textContent = prefix;
      line.appendChild(pre);
    }

    const span = document.createElement('span');
    span.className = `t-text ${cls}`;
    line.appendChild(span);
    outputEl.appendChild(line);

    let i = 0;
    const interval = setInterval(() => {
      if (i < text.length) {
        span.textContent += text[i++];
        outputEl.scrollTop = outputEl.scrollHeight;
      } else {
        clearInterval(interval);
        resolve();
      }
    }, delay);
  });
}

function onInputKeydown(e) {
  if (e.key === 'Enter') {
    const val = inputEl.value.trim();
    if (!val) return;
    handleCommand(val);
    player.cmdHistory.unshift(val);
    player.historyIdx = -1;
    inputEl.value = '';
    updateAutocomplete('');
  } else if (e.key === 'ArrowUp') {
    e.preventDefault();
    if (player.historyIdx < player.cmdHistory.length - 1) {
      player.historyIdx++;
      inputEl.value = player.cmdHistory[player.historyIdx] || '';
    }
  } else if (e.key === 'ArrowDown') {
    e.preventDefault();
    if (player.historyIdx > -1) {
      player.historyIdx--;
      inputEl.value = player.historyIdx >= 0 ? player.cmdHistory[player.historyIdx] : '';
    }
  } else if (e.key === 'Tab') {
    e.preventDefault();
    doAutocomplete();
  }
}

function onInputChange() {
  updateAutocomplete(inputEl.value);
}

function doAutocomplete() {
  const val = inputEl.value.toLowerCase();
  if (!val) return;
  const matches = Object.keys(COMMANDS).filter(k => k.startsWith(val) && COMMANDS[k].name.toLowerCase() === k);
  if (matches.length === 1) {
    inputEl.value = matches[0];
    updateAutocomplete('');
  } else if (matches.length > 1) {
    updateAutocomplete(val);
  }
}

function updateAutocomplete(val) {
  autocompleteEl.innerHTML = '';
  if (!val) return;
  const v = val.toLowerCase().split(' ')[0];
  const matches = Object.keys(COMMANDS).filter(k => k.startsWith(v) && COMMANDS[k].name.toLowerCase() === k);
  matches.slice(0, 8).forEach(m => {
    const chip = document.createElement('span');
    chip.className = 'hint-chip';
    chip.textContent = m;
    chip.onclick = () => { inputEl.value = m + ' '; inputEl.focus(); updateAutocomplete(''); };
    autocompleteEl.appendChild(chip);
  });
}

function handleCommand(raw) {
  if (player.inProgress) {
    handleHackInput(raw);
    return;
  }

  // Echo command
  print(`${raw}`, 'white', `root@ghost:~$ `);

  const parts = raw.trim().split(/\s+/);
  const cmd   = parts[0].toLowerCase();
  const args  = parts.slice(1);

  if (COMMANDS[cmd]) {
    COMMANDS[cmd].fn(args, raw);
  } else {
    print(`Command not found: ${cmd}`, 'red');
    print(`Type <span class="t-text cyan">help</span> to see available commands.`, 'gray');
  }
  printBlank();
}

// ─── HACK STATE MACHINE ───────────────────────────────────
function startHack() {
  const hack   = HACKS[player.activeHack];
  const target = TARGETS.find(t => t.id === player.activeTarget);

  if (!hack || !target) {
    print("❌ Select a hack with <span class='t-text cyan'>use [hackname]</span> and target with <span class='t-text cyan'>attack [target]</span>", 'red');
    return;
  }

  player.inProgress = true;
  player.stepIndex  = 0;

  inputEl.disabled = false;
  document.getElementById('input-status').textContent = 'HACKING';
  document.getElementById('input-status').style.color = 'var(--red)';

  document.getElementById('inf-hack').textContent    = hack.name;
  document.getElementById('inf-target').textContent  = target.name;
  document.getElementById('inf-progress').textContent= `0/${hack.steps.length}`;

  // Show progress panel
  const prog = document.getElementById('hack-progress');
  prog.classList.add('visible');
  renderProgSteps(hack);

  printBanner(`💀 EXECUTING: ${hack.name}`, 'red bold');
  print(`🎯 Target   : ${target.icon} ${target.name}`, 'cyan');
  print(`🛡️  Defense  : ${target.defense}%`, 'red');
  print(`📊 Success  : ~${getAdjustedSuccess(hack, target)}%`, 'yellow');
  print(`👁️  Detect   : ~${getAdjustedDetect(hack, target)}%`, 'magenta');
  printBlank();
  print(`Type each command to execute the hack sequence.`, 'gray');
  printBlank();

  printStep(hack.steps[0], 0, hack.steps.length);
}

function renderProgSteps(hack) {
  const el = document.getElementById('prog-steps');
  el.innerHTML = '';
  hack.steps.forEach((step, i) => {
    const div = document.createElement('div');
    div.className = 'prog-step pending';
    div.id = `pstep-${i}`;
    div.innerHTML = `<span class="step-icon">◯</span><span class="step-text">${step.desc}</span>`;
    el.appendChild(div);
  });
}

function updateProgStep(index, status) {
  const el = document.getElementById(`pstep-${index}`);
  if (!el) return;
  el.className = `prog-step ${status}`;
  const icon = el.querySelector('.step-icon');
  if (status === 'done')   icon.textContent = '✓';
  else if (status === 'active') icon.textContent = '►';
  else icon.textContent = '◯';

  // Progress bar
  const hack = HACKS[player.activeHack];
  const pct  = Math.round((index / hack.steps.length) * 100);
  document.getElementById('prog-bar').style.width = pct + '%';
  document.getElementById('inf-progress').textContent = `${index}/${hack.steps.length}`;
}

function printStep(step, index, total) {
  print(`<span style="color:var(--gray)">[${index + 1}/${total}]</span> <span style="color:var(--gray)">${step.desc}</span>`, '');
  print(``, 'gray', `root@ghost:~$ `);
  updateProgStep(index, 'active');
}

function handleHackInput(raw) {
  const hack   = HACKS[player.activeHack];
  const target = TARGETS.find(t => t.id === player.activeTarget);
  const step   = hack.steps[player.stepIndex];

  // Echo
  print(`${raw}`, 'white', `root@ghost:~$ `);

  // Check if command matches (flexible — strip extra spaces, case insensitive base command)
  const expected  = step.cmd.split(' ')[0].toLowerCase();
  const given     = raw.trim().split(' ')[0].toLowerCase();
  const isCorrect = given === expected;

  if (!isCorrect) {
    print(`❌ Wrong command. Expected: <span class="t-text cyan">${step.cmd.split(' ')[0]}</span>`, 'red');
    print(`💡 Hint: ${step.desc}`, 'gray');
    printBlank();
    return;
  }

  // Correct!
  updateProgStep(player.stepIndex, 'done');
  print(`✓ ${step.desc} — <span class="t-text green">OK</span>`, 'gray');

  // Fake output lines
  const fakeOutputs = [
    `   → ${generateFakeHex()}`,
    `   → Process bound to phantom PID ${Math.floor(Math.random()*9000)+1000}`,
    `   → Memory segment 0x${generateFakeHex(8)} allocated`,
    `   → Packet chain initialized [${Math.floor(Math.random()*512)+64} nodes]`,
  ];
  const numLines = Math.floor(Math.random() * 2) + 1;
  for (let i = 0; i < numLines; i++) {
    print(fakeOutputs[Math.floor(Math.random() * fakeOutputs.length)], 'gray');
  }

  player.stepIndex++;

  if (player.stepIndex >= hack.steps.length) {
    // Hack sequence complete — resolve outcome
    resolveHack(hack, target);
  } else {
    printBlank();
    printStep(hack.steps[player.stepIndex], player.stepIndex, hack.steps.length);
    updateProgStep(player.stepIndex, 'active');
  }
}

function generateFakeHex(len = 16) {
  let s = '';
  for (let i = 0; i < len; i++) s += Math.floor(Math.random() * 16).toString(16).toUpperCase();
  return s;
}

function getAdjustedSuccess(hack, target) {
  let s = hack.successBase + getSuccessBoost() - target.defense * 0.3;
  return Math.round(Math.max(5, Math.min(95, s)));
}

function getAdjustedDetect(hack, target) {
  let d = hack.detectRisk - getDetectReduce() + target.defense * 0.2;
  return Math.round(Math.max(5, Math.min(95, d)));
}

function resolveHack(hack, target) {
  player.inProgress = false;
  document.getElementById('input-status').textContent = 'READY';
  document.getElementById('input-status').style.color = '';

  // Full progress bar
  document.getElementById('prog-bar').style.width = '100%';
  document.getElementById('inf-progress').textContent = `${hack.steps.length}/${hack.steps.length}`;

  const adjSuccess = getAdjustedSuccess(hack, target);
  const adjDetect  = getAdjustedDetect(hack, target);

  const roll       = Math.random() * 100;
  const detectRoll = Math.random() * 100;
  const success    = roll <= adjSuccess;
  const detected   = detectRoll <= adjDetect;

  setTimeout(() => {
    printBlank();
    print('Analyzing breach result...', 'gray');

    setTimeout(() => {
      if (success) {
        // Calculate reward
        const [rMin, rMax] = hack.reward;
        let reward = Math.floor(Math.random() * (rMax - rMin) + rMin);
        reward = Math.floor(reward * target.mult * (1 + getRewardBoost() / 100));

        let xpGain = Math.floor(hack.xp * (1 + getXPBoost() / 100));

        if (detected) {
          const deduction = Math.floor(reward * 0.3 * (1 - getPenaltyReduce() / 100));
          reward -= deduction;
          player.detected++;
          print(`⚠️  PARTIAL DETECTION — Lost ${deduction} CR in trace cleanup`, 'yellow');
        }

        player.credits += reward;
        player.xp      += xpGain;
        player.wins++;

        printBanner('✅ HACK SUCCESSFUL — BREACH COMPLETE', 'green bold');
        print(`💰 Credits  : +${reward} CR  (Total: ${player.credits} CR)`, 'yellow');
        print(`⭐ XP       : +${xpGain}  (Total: ${player.xp})`, 'cyan');

        const leveled = checkLevelUp();
        if (leveled) {
          printBlank();
          print(`🎉 LEVEL UP! You are now Level ${player.level}: ${getTitle()}`, 'magenta bold');
          const unlocks = Object.values(HACKS).filter(h => h.levelReq === player.level).map(h => h.name);
          if (unlocks.length) print(`🔓 NEW HACKS UNLOCKED: ${unlocks.join(', ')}`, 'cyan');
          document.getElementById('app').classList.add('lvlup-flash');
          setTimeout(() => document.getElementById('app').classList.remove('lvlup-flash'), 1000);
        }

        logEntry('SUCCESS', hack.name, target.name, reward, xpGain, detected);
        showResult(true, reward, xpGain, detected);
      } else {
        // Fail
        let penalty = Math.floor((Math.random() * 60 + 20) * (1 - getPenaltyReduce() / 100));
        player.credits = Math.max(0, player.credits - penalty);
        player.losses++;

        if (detected) {
          player.detected++;
          document.getElementById('app').classList.add('detect-flash');
          setTimeout(() => document.getElementById('app').classList.remove('detect-flash'), 1500);
          print(`🚨 DETECTED! Ghost signature logged. Detections: ${player.detected}`, 'red bold');
        }

        printBanner('❌ HACK FAILED — DEFENSE BLOCKED', 'red bold');
        print(`💸 Trace cleanup cost: -${penalty} CR`, 'red');

        logEntry('FAIL', hack.name, target.name, -penalty, 0, detected);
        showResult(false, -penalty, 0, detected);
      }

      updateHUD();
      renderTargetList();
      document.getElementById('hack-progress').classList.remove('visible');

    }, 800);
  }, 600);
}

// ─── RESULT POPUP ─────────────────────────────────────────
function showResult(success, reward, xp, detected) {
  const popup  = document.getElementById('result-popup');
  const title  = document.getElementById('result-title');
  const detail = document.getElementById('result-details');

  popup.className = success ? '' : 'fail';
  title.textContent = success ? '✅ BREACH COMPLETE' : '❌ HACK FAILED';

  if (success) {
    detail.innerHTML = `
      <span style="color:var(--yellow)">💰 +${reward} CR</span><br>
      <span style="color:var(--cyan)">⭐ +${xp} XP</span><br>
      ${detected ? '<span style="color:var(--yellow)">⚠️ Partial Detection</span>' : '<span style="color:var(--green)">👻 Undetected</span>'}
    `;
  } else {
    detail.innerHTML = `
      <span style="color:var(--red)">💸 ${reward} CR</span><br>
      ${detected ? '<span style="color:var(--red)">🚨 DETECTED!</span>' : '<span style="color:var(--gray)">Undetected</span>'}
    `;
  }

  popup.style.display = 'block';
  setTimeout(() => { popup.style.display = 'none'; }, 3000);
}

// ─── UPGRADE HELPERS ──────────────────────────────────────
function getSuccessBoost() {
  return Object.entries(player.upgrades)
    .filter(([,v]) => v)
    .reduce((s,[k]) => s + (UPGRADES[k]?.effect?.successBoost || 0), 0);
}

function getDetectReduce() {
  return Object.entries(player.upgrades)
    .filter(([,v]) => v)
    .reduce((s,[k]) => s + (UPGRADES[k]?.effect?.detectReduce || 0), 0);
}

function getXPBoost() {
  return Object.entries(player.upgrades)
    .filter(([,v]) => v)
    .reduce((s,[k]) => s + (UPGRADES[k]?.effect?.xpBoost || 0), 0);
}

function getRewardBoost() {
  return Object.entries(player.upgrades)
    .filter(([,v]) => v)
    .reduce((s,[k]) => s + (UPGRADES[k]?.effect?.rewardBoost || 0), 0);
}

function getPenaltyReduce() {
  return Object.entries(player.upgrades)
    .filter(([,v]) => v)
    .reduce((s,[k]) => s + (UPGRADES[k]?.effect?.penaltyReduce || 0), 0);
}

// ─── LEVEL / TITLE ────────────────────────────────────────
function checkLevelUp() {
  if (player.level >= LEVEL_XP.length - 1) return false;
  if (player.xp >= LEVEL_XP[player.level]) {
    player.level++;
    return true;
  }
  return false;
}

function getTitle() {
  return LEVEL_TITLES[Math.min(player.level - 1, LEVEL_TITLES.length - 1)];
}

// ─── LOG ──────────────────────────────────────────────────
function logEntry(result, hack, target, reward, xp, detected) {
  const rows = document.getElementById('log-rows');
  const div  = document.createElement('div');
  div.className = 'log-entry';
  div.innerHTML = `
    <div>${result === 'SUCCESS'
      ? '<span class="badge-success">WIN</span>'
      : '<span class="badge-fail">FAIL</span>'}
      ${detected ? ' <span class="badge-detect">⚠</span>' : ''}
    </div>
    <div style="color:var(--green);font-size:10px">${hack}</div>
    <div style="color:var(--cyan);font-size:10px">${target}</div>
    <div style="color:${reward > 0 ? 'var(--yellow)' : 'var(--red)'}">${reward > 0 ? '+' : ''}${reward} CR</div>
    <div style="color:var(--cyan)">${xp > 0 ? '+' + xp : '—'}</div>
  `;
  rows.prepend(div);
}

// ─── HUD ──────────────────────────────────────────────────
function updateHUD() {
  document.getElementById('stat-name').textContent    = player.name;
  document.getElementById('stat-level').textContent   = player.level;
  document.getElementById('stat-credits').textContent = player.credits + ' CR';
  document.getElementById('stat-caught').textContent  = player.detected;
  document.getElementById('stat-wins').textContent    = player.wins;
  document.getElementById('stat-title').textContent   = getTitle();

  const prevXP = LEVEL_XP[player.level - 1] || 0;
  const nextXP = LEVEL_XP[player.level] || LEVEL_XP[LEVEL_XP.length - 1];
  const pct    = Math.min(100, Math.round(((player.xp - prevXP) / (nextXP - prevXP)) * 100));
  document.getElementById('xp-fill').style.width = pct + '%';
  document.getElementById('xp-cur').textContent  = player.xp;
  document.getElementById('xp-next').textContent = nextXP;

  document.getElementById('inf-succ').textContent = '+' + getSuccessBoost() + '%';
  document.getElementById('inf-det').textContent  = '-' + getDetectReduce() + '%';
  document.getElementById('inf-xp').textContent   = '+' + getXPBoost() + '%';
  document.getElementById('inf-rew').textContent  = '+' + getRewardBoost() + '%';

  const affordable = Object.entries(UPGRADES).filter(([k, u]) =>
    !player.upgrades[k] && player.credits >= u.cost && player.level >= u.levelReq
  ).length;
  const badge = document.getElementById('shop-badge');
  badge.textContent    = affordable;
  badge.style.display  = affordable > 0 ? 'inline' : 'none';
}

// ─── RENDER FUNCTIONS ─────────────────────────────────────
function renderTargetList() {
  const list = document.getElementById('target-list');
  list.innerHTML = '';
  TARGETS.forEach(t => {
    const locked   = player.level < t.minLevel;
    const selected = player.activeTarget === t.id;
    const div = document.createElement('div');
    div.className = `target-card${locked ? ' locked' : ''}${selected ? ' selected' : ''}`;
    div.innerHTML = `
      <div class="target-name">${t.icon} ${t.name}</div>
      <div class="target-meta">
        <span class="target-defense">DEF ${t.defense}%</span>
        <span class="target-mult">×${t.mult}</span>
        ${locked ? `<span style="color:var(--red);font-size:9px">LVL ${t.minLevel}</span>` : ''}
      </div>
      <div class="def-bar"><div class="def-bar-fill" style="width:${t.defense}%"></div></div>
    `;
    if (!locked) {
      div.onclick = () => {
        player.activeTarget = t.id;
        renderTargetList();
        document.getElementById('inf-tname').textContent = t.name;
        document.getElementById('inf-tdef').textContent  = t.defense + '%';
        document.getElementById('inf-tmult').textContent = '×' + t.mult;
        showToast('Target: ' + t.name);
      };
    }
    list.appendChild(div);
  });
}

function renderDictionary() {
  const panel = document.getElementById('hack-panel');
  panel.innerHTML = '';
  Object.values(HACKS).forEach(hack => {
    const locked   = player.level < hack.levelReq;
    const selected = player.activeHack === hack.name;
    const div = document.createElement('div');
    div.className = `hack-card${locked ? ' locked' : ''}${selected ? ' selected' : ''}`;
    div.innerHTML = `
      <div class="hack-card-header">
        <span class="hack-name">${hack.name}</span>
        <span class="hack-lvl${locked ? ' locked-lvl' : ''}">LVL ${hack.levelReq}</span>
      </div>
      <div class="hack-desc">${hack.desc}</div>
      <div class="hack-stats">
        <div class="hs"><span class="hs-label">SUCCESS</span><span class="hs-val g">${hack.successBase}%</span></div>
        <div class="hs"><span class="hs-label">DETECT</span><span class="hs-val r">${hack.detectRisk}%</span></div>
        <div class="hs"><span class="hs-label">REWARD</span><span class="hs-val y">${hack.reward[0]}–${hack.reward[1]} CR</span></div>
        <div class="hs"><span class="hs-label">XP</span><span class="hs-val c">${hack.xp}</span></div>
      </div>
      <div class="cmd-list">
        ${hack.steps.map(s => `<div class="cmd-entry"><span class="cmd-code">${s.cmd}</span><span class="cmd-desc">${s.desc}</span></div>`).join('')}
      </div>
    `;
    if (!locked) {
      div.onclick = () => {
        player.activeHack = hack.name;
        renderDictionary();
        document.getElementById('inf-hack').textContent = hack.name;
        showToast('Hack loaded: ' + hack.name);
      };
    }
    panel.appendChild(div);
  });
}

function renderShop() {
  const panel = document.getElementById('shop-panel');
  panel.innerHTML = '';
  Object.entries(UPGRADES).forEach(([key, upg]) => {
    const owned   = !!player.upgrades[key];
    const locked  = player.level < upg.levelReq;
    const buyable = !owned && !locked && player.credits >= upg.cost;
    const div = document.createElement('div');
    div.className = `shop-card${owned ? ' owned' : ''}${locked ? ' locked' : ''}${buyable ? ' buyable' : ''}`;
    div.innerHTML = `
      <div class="shop-header">
        <span class="shop-name">${upg.icon} ${upg.name}</span>
        <span class="shop-cost ${owned ? 'owned-tag' : locked ? 'locked-tag' : ''}">
          ${owned ? '✓ OWNED' : locked ? 'LVL ' + upg.levelReq : upg.cost + ' CR'}
        </span>
      </div>
      <div class="shop-desc">${upg.desc}</div>
      <div class="shop-effect">${Object.entries(upg.effect).map(([k,v]) => k + ': ' + v).join(' · ')}</div>
      ${buyable ? `<button class="buy-btn" onclick="buyUpgrade('${key}')">[ PURCHASE ]</button>` : ''}
    `;
    panel.appendChild(div);
  });
}

function buyUpgrade(key) {
  const upg = UPGRADES[key];
  if (!upg || player.upgrades[key]) return;
  if (player.credits < upg.cost) { showToast('Insufficient credits!'); return; }
  if (player.level < upg.levelReq) { showToast('Level too low!'); return; }
  player.credits -= upg.cost;
  player.upgrades[key] = true;
  updateHUD();
  renderShop();
  showToast('Installed: ' + upg.name);
  print('🛒 Purchased: <span class="t-text yellow">' + upg.name + '</span>');
}

// ─── TAB SWITCHING ────────────────────────────────────────
function switchTab(name) {
  document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.nav-btn').forEach(b => b.classList.remove('active'));
  const panel = document.getElementById('tab-' + name);
  if (panel) panel.classList.add('active');
  const btns = document.querySelectorAll('.nav-btn');
  btns.forEach(b => { if (b.getAttribute('onclick')?.includes("'" + name + "'")) b.classList.add('active'); });
  if (name === 'dictionary') renderDictionary();
  if (name === 'shop') renderShop();
}

// ─── TOAST ────────────────────────────────────────────────
function showToast(msg) {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.style.display = 'block';
  clearTimeout(t._timer);
  t._timer = setTimeout(() => { t.style.display = 'none'; }, 2500);
}


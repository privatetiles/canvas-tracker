<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>TERMINAL BREACH</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Share+Tech+Mono&family=VT323&display=swap');

  /* ─── RESET & BASE ─── */
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --green:      #00ff41;
    --green-dim:  #00aa2a;
    --green-dark: #003010;
    --red:        #ff003c;
    --yellow:     #ffd700;
    --cyan:       #00ffff;
    --magenta:    #ff00ff;
    --gray:       #555;
    --white:      #e0e0e0;
    --bg:         #0a0a0a;
    --panel:      #0d1a0d;
    --border:     #00ff4133;
    --glow:       0 0 10px #00ff41, 0 0 20px #00ff4155;
    --glow-red:   0 0 10px #ff003c, 0 0 20px #ff003c55;
    --glow-cyan:  0 0 10px #00ffff, 0 0 20px #00ffff55;
  }

  html, body {
    height: 100%;
    background: var(--bg);
    color: var(--green);
    font-family: 'Share Tech Mono', 'Courier New', monospace;
    font-size: 14px;
    overflow: hidden;
  }

  /* ─── SCANLINES ─── */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background: repeating-linear-gradient(
      to bottom,
      transparent 0px,
      transparent 2px,
      rgba(0,0,0,0.15) 2px,
      rgba(0,0,0,0.15) 4px
    );
    pointer-events: none;
    z-index: 9999;
  }

  /* ─── CRT FLICKER ─── */
  @keyframes flicker {
    0%,100%{ opacity:1; }
    92%    { opacity:1; }
    93%    { opacity:0.85; }
    94%    { opacity:1; }
    96%    { opacity:0.9; }
    97%    { opacity:1; }
  }
  body { animation: flicker 8s infinite; }

  /* ─── LAYOUT ─── */
  #app {
    display: grid;
    grid-template-rows: auto 1fr auto;
    grid-template-columns: 280px 1fr 260px;
    grid-template-areas:
      "header  header  header"
      "sidebar main    info"
      "footer  footer  footer";
    height: 100vh;
    gap: 1px;
    background: #001a00;
  }

  /* ─── HEADER ─── */
  #header {
    grid-area: header;
    background: var(--panel);
    border-bottom: 1px solid var(--border);
    padding: 8px 16px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
  }

  #logo {
    font-family: 'VT323', monospace;
    font-size: 28px;
    color: var(--green);
    text-shadow: var(--glow);
    letter-spacing: 4px;
    white-space: nowrap;
  }

  #logo span { color: var(--red); text-shadow: var(--glow-red); }

  .stat-bar {
    display: flex;
    gap: 20px;
    flex-wrap: wrap;
  }

  .stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2px;
    min-width: 70px;
  }

  .stat-label {
    font-size: 9px;
    color: var(--gray);
    letter-spacing: 2px;
    text-transform: uppercase;
  }

  .stat-value {
    font-size: 16px;
    color: var(--yellow);
    text-shadow: 0 0 8px var(--yellow);
    font-family: 'VT323', monospace;
  }

  .stat-value.green  { color: var(--green); text-shadow: var(--glow); }
  .stat-value.cyan   { color: var(--cyan);  text-shadow: var(--glow-cyan); }
  .stat-value.red    { color: var(--red);   text-shadow: var(--glow-red); }
  .stat-value.magenta{ color: var(--magenta); text-shadow: 0 0 8px var(--magenta); }

  /* XP Bar */
  #xp-bar-wrap {
    display: flex;
    flex-direction: column;
    gap: 3px;
    min-width: 120px;
  }

  #xp-label {
    font-size: 9px;
    color: var(--gray);
    letter-spacing: 2px;
  }

  #xp-bar {
    height: 8px;
    background: #001500;
    border: 1px solid var(--green-dim);
    border-radius: 2px;
    overflow: hidden;
  }

  #xp-fill {
    height: 100%;
    background: linear-gradient(90deg, var(--green-dim), var(--green));
    box-shadow: var(--glow);
    transition: width 0.5s ease;
    width: 0%;
  }

  /* ─── SIDEBAR ─── */
  #sidebar {
    grid-area: sidebar;
    background: var(--panel);
    border-right: 1px solid var(--border);
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  .panel-title {
    font-size: 10px;
    letter-spacing: 3px;
    color: var(--gray);
    padding: 8px 12px;
    border-bottom: 1px solid var(--border);
    text-transform: uppercase;
  }

  /* Nav Tabs */
  #nav-tabs {
    display: flex;
    flex-direction: column;
    padding: 8px 0;
    gap: 2px;
  }

  .nav-btn {
    background: none;
    border: none;
    color: var(--green-dim);
    font-family: 'Share Tech Mono', monospace;
    font-size: 13px;
    padding: 8px 14px;
    text-align: left;
    cursor: pointer;
    transition: all 0.15s;
    display: flex;
    align-items: center;
    gap: 10px;
    border-left: 3px solid transparent;
    letter-spacing: 1px;
  }

  .nav-btn:hover, .nav-btn.active {
    color: var(--green);
    background: rgba(0,255,65,0.08);
    border-left-color: var(--green);
    text-shadow: var(--glow);
  }

  .nav-btn .nav-icon { font-size: 16px; width: 20px; }
  .nav-btn .nav-badge {
    margin-left: auto;
    background: var(--green);
    color: #000;
    font-size: 10px;
    padding: 1px 5px;
    border-radius: 8px;
    font-weight: bold;
  }

  /* Sidebar sub-panels */
  #target-list {
    flex: 1;
    overflow-y: auto;
    padding: 6px;
    scrollbar-width: thin;
    scrollbar-color: var(--green-dim) transparent;
  }

  .target-card {
    border: 1px solid var(--border);
    background: rgba(0,255,65,0.03);
    padding: 8px 10px;
    margin-bottom: 6px;
    cursor: pointer;
    transition: all 0.2s;
    border-radius: 3px;
  }

  .target-card:hover, .target-card.selected {
    border-color: var(--green);
    background: rgba(0,255,65,0.08);
    box-shadow: var(--glow);
  }

  .target-card.locked {
    opacity: 0.35;
    cursor: not-allowed;
    border-color: var(--gray);
  }

  .target-name {
    font-size: 12px;
    color: var(--green);
    margin-bottom: 4px;
  }

  .target-meta {
    font-size: 10px;
    color: var(--gray);
    display: flex;
    justify-content: space-between;
  }

  .target-defense {
    color: var(--red);
    font-size: 10px;
  }

  .target-mult {
    color: var(--yellow);
    font-size: 10px;
  }

  .def-bar {
    height: 3px;
    background: #001500;
    margin-top: 4px;
    border-radius: 1px;
    overflow: hidden;
  }

  .def-bar-fill {
    height: 100%;
    background: linear-gradient(90deg, var(--green), var(--red));
  }

  /* ─── MAIN TERMINAL ─── */
  #main {
    grid-area: main;
    background: var(--bg);
    display: flex;
    flex-direction: column;
    overflow: hidden;
    position: relative;
  }

  /* Tab panels */
  .tab-panel {
    display: none;
    flex: 1;
    flex-direction: column;
    overflow: hidden;
  }

  .tab-panel.active { display: flex; }

  /* Terminal Output */
  #terminal-output {
    flex: 1;
    overflow-y: auto;
    padding: 12px 16px;
    scrollbar-width: thin;
    scrollbar-color: var(--green-dim) transparent;
    font-size: 13px;
    line-height: 1.7;
  }

  .t-line { display: flex; align-items: flex-start; gap: 8px; margin: 1px 0; }
  .t-prefix { color: var(--gray); white-space: nowrap; flex-shrink: 0; }
  .t-text   { color: var(--green); word-break: break-all; }

  .t-text.red     { color: var(--red); }
  .t-text.yellow  { color: var(--yellow); }
  .t-text.cyan    { color: var(--cyan); }
  .t-text.magenta { color: var(--magenta); }
  .t-text.gray    { color: var(--gray); }
  .t-text.white   { color: var(--white); }
  .t-text.bold    { font-weight: bold; text-shadow: var(--glow); }

  /* Input Line */
  #input-area {
    border-top: 1px solid var(--border);
    padding: 10px 16px;
    display: flex;
    align-items: center;
    gap: 8px;
    background: var(--panel);
    flex-shrink: 0;
  }

  #input-prompt {
    color: var(--green);
    white-space: nowrap;
    text-shadow: var(--glow);
    font-size: 14px;
  }

  #terminal-input {
    flex: 1;
    background: none;
    border: none;
    outline: none;
    color: var(--green);
    font-family: 'Share Tech Mono', monospace;
    font-size: 14px;
    caret-color: var(--green);
    text-shadow: var(--glow);
  }

  #terminal-input::placeholder { color: var(--gray); }

  #input-status {
    font-size: 10px;
    color: var(--gray);
    white-space: nowrap;
  }

  /* Autocomplete hints */
  #autocomplete {
    padding: 4px 16px 6px;
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    background: var(--panel);
    border-top: 1px solid #001500;
    min-height: 24px;
  }

  .hint-chip {
    font-size: 10px;
    color: var(--green-dim);
    border: 1px solid var(--border);
    padding: 1px 6px;
    border-radius: 2px;
    cursor: pointer;
    transition: all 0.1s;
    letter-spacing: 1px;
  }

  .hint-chip:hover {
    color: var(--green);
    border-color: var(--green);
    text-shadow: var(--glow);
  }

  /* ─── HACK PANEL (dict/shop/log) ─── */
  #hack-panel, #shop-panel, #log-panel {
    flex: 1;
    overflow-y: auto;
    padding: 12px;
    scrollbar-width: thin;
    scrollbar-color: var(--green-dim) transparent;
  }

  /* Hack Cards */
  .hack-card {
    border: 1px solid var(--border);
    background: rgba(0,255,65,0.02);
    padding: 10px 12px;
    margin-bottom: 8px;
    border-radius: 3px;
    cursor: pointer;
    transition: all 0.2s;
  }

  .hack-card:hover:not(.locked) {
    border-color: var(--green);
    background: rgba(0,255,65,0.07);
    box-shadow: var(--glow);
  }

  .hack-card.locked {
    opacity: 0.3;
    cursor: not-allowed;
  }

  .hack-card.selected {
    border-color: var(--cyan);
    box-shadow: var(--glow-cyan);
  }

  .hack-card-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 4px;
  }

  .hack-name {
    font-size: 14px;
    color: var(--green);
    letter-spacing: 2px;
    font-family: 'VT323', monospace;
  }

  .hack-lvl {
    font-size: 10px;
    padding: 2px 6px;
    border-radius: 2px;
    background: rgba(0,255,65,0.1);
    color: var(--green);
    border: 1px solid var(--border);
  }

  .hack-lvl.locked-lvl {
    background: rgba(255,0,60,0.1);
    color: var(--red);
    border-color: var(--red);
  }

  .hack-desc { font-size: 11px; color: var(--gray); margin-bottom: 6px; }

  .hack-stats {
    display: flex;
    gap: 12px;
    font-size: 11px;
  }

  .hs { display: flex; flex-direction: column; gap: 1px; }
  .hs-label { font-size: 9px; color: var(--gray); letter-spacing: 1px; }
  .hs-val   { color: var(--yellow); font-family: 'VT323', monospace; font-size: 14px; }
  .hs-val.g { color: var(--green); }
  .hs-val.r { color: var(--red); }
  .hs-val.c { color: var(--cyan); }

  /* Command list shown on hack card */
  .cmd-list {
    margin-top: 6px;
    padding-top: 6px;
    border-top: 1px solid var(--border);
    display: none;
  }

  .hack-card.selected .cmd-list { display: block; }

  .cmd-entry {
    font-size: 11px;
    color: var(--gray);
    padding: 2px 0;
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .cmd-entry .cmd-code {
    color: var(--cyan);
    font-size: 12px;
    background: rgba(0,255,255,0.05);
    padding: 1px 4px;
    border: 1px solid rgba(0,255,255,0.2);
    border-radius: 2px;
  }

  .cmd-entry .cmd-desc { color: var(--gray); font-size: 10px; }

  /* ─── SHOP CARDS ─── */
  .shop-card {
    border: 1px solid var(--border);
    background: rgba(0,255,65,0.02);
    padding: 10px 12px;
    margin-bottom: 8px;
    border-radius: 3px;
    transition: all 0.2s;
  }

  .shop-card.owned  { border-color: var(--green-dim); background: rgba(0,255,65,0.05); }
  .shop-card.locked { opacity: 0.3; }
  .shop-card.buyable:hover {
    border-color: var(--yellow);
    background: rgba(255,215,0,0.05);
    box-shadow: 0 0 10px rgba(255,215,0,0.2);
    cursor: pointer;
  }

  .shop-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 4px;
  }

  .shop-name {
    font-size: 13px;
    color: var(--yellow);
    letter-spacing: 2px;
    font-family: 'VT323', monospace;
  }

  .shop-cost {
    font-size: 12px;
    color: var(--yellow);
    font-family: 'VT323', monospace;
  }

  .shop-cost.owned-tag { color: var(--green); }
  .shop-cost.locked-tag { color: var(--red); }

  .shop-desc   { font-size: 11px; color: var(--gray); margin-bottom: 4px; }
  .shop-effect { font-size: 10px; color: var(--cyan); }

  /* ─── LOG TABLE ─── */
  .log-entry {
    display: grid;
    grid-template-columns: 70px 1fr 1fr 80px 60px;
    gap: 6px;
    padding: 5px 8px;
    border-bottom: 1px solid #001500;
    font-size: 11px;
    align-items: center;
  }

  .log-entry:hover { background: rgba(0,255,65,0.03); }

  .log-header {
    font-size: 9px;
    color: var(--gray);
    letter-spacing: 2px;
    text-transform: uppercase;
  }

  .badge-success {
    color: #000;
    background: var(--green);
    padding: 1px 6px;
    border-radius: 2px;
    font-size: 10px;
    text-align: center;
  }

  .badge-fail {
    color: #000;
    background: var(--red);
    padding: 1px 6px;
    border-radius: 2px;
    font-size: 10px;
    text-align: center;
  }

  .badge-detect {
    color: #000;
    background: var(--yellow);
    padding: 1px 4px;
    border-radius: 2px;
    font-size: 10px;
    text-align: center;
  }

  /* ─── RIGHT INFO PANEL ─── */
  #info {
    grid-area: info;
    background: var(--panel);
    border-left: 1px solid var(--border);
    display: flex;
    flex-direction: column;
    overflow: hidden;
    font-size: 12px;
  }

  #info-title { }

  #info-content {
    flex: 1;
    overflow-y: auto;
    padding: 8px;
    scrollbar-width: thin;
    scrollbar-color: var(--green-dim) transparent;
  }

  .info-section { margin-bottom: 12px; }

  .info-section-title {
    font-size: 9px;
    color: var(--gray);
    letter-spacing: 3px;
    text-transform: uppercase;
    border-bottom: 1px solid var(--border);
    padding-bottom: 4px;
    margin-bottom: 6px;
  }

  .info-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 3px 0;
    border-bottom: 1px solid #001500;
    font-size: 11px;
  }

  .info-key { color: var(--gray); }
  .info-val { color: var(--green); font-family: 'VT323', monospace; font-size: 14px; }
  .info-val.y { color: var(--yellow); }
  .info-val.r { color: var(--red); }
  .info-val.c { color: var(--cyan); }
  .info-val.m { color: var(--magenta); }

  /* Active hack progress */
  #hack-progress {
    padding: 8px;
    border-top: 1px solid var(--border);
    display: none;
  }

  #hack-progress.visible { display: block; }

  .prog-title {
    font-size: 9px;
    color: var(--gray);
    letter-spacing: 2px;
    margin-bottom: 6px;
  }

  .prog-step {
    font-size: 11px;
    padding: 3px 0;
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .prog-step .step-icon { font-size: 12px; }
  .prog-step .step-text { color: var(--gray); }
  .prog-step.done .step-text { color: var(--green); text-shadow: var(--glow); }
  .prog-step.active .step-text { color: var(--cyan); text-shadow: var(--glow-cyan); }
  .prog-step.pending .step-icon { opacity: 0.3; }

  /* ─── FOOTER ─── */
  #footer {
    grid-area: footer;
    background: var(--panel);
    border-top: 1px solid var(--border);
    padding: 5px 16px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 10px;
    color: var(--gray);
  }

  #footer .f-left { display: flex; gap: 20px; }
  #footer .f-key { color: var(--green-dim); letter-spacing: 1px; }

  /* ─── MODAL ─── */
  #modal-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.85);
    z-index: 1000;
    align-items: center;
    justify-content: center;
  }

  #modal-overlay.open { display: flex; }

  #modal {
    background: var(--panel);
    border: 1px solid var(--green);
    box-shadow: var(--glow);
    padding: 24px 28px;
    min-width: 400px;
    max-width: 500px;
    border-radius: 4px;
    position: relative;
  }

  #modal-title {
    font-family: 'VT323', monospace;
    font-size: 24px;
    color: var(--green);
    text-shadow: var(--glow);
    margin-bottom: 12px;
    letter-spacing: 3px;
  }

  #modal-body { font-size: 13px; color: var(--white); line-height: 1.8; }

  #modal-input-wrap {
    display: flex;
    gap: 8px;
    margin-top: 14px;
    border: 1px solid var(--green);
    padding: 8px 10px;
    background: rgba(0,255,65,0.05);
  }

  #modal-prompt { color: var(--green); text-shadow: var(--glow); }

  #modal-input {
    flex: 1;
    background: none;
    border: none;
    outline: none;
    color: var(--green);
    font-family: 'Share Tech Mono', monospace;
    font-size: 14px;
    caret-color: var(--green);
    text-shadow: var(--glow);
  }

  .modal-btn {
    margin-top: 12px;
    margin-right: 8px;
    background: none;
    border: 1px solid var(--green);
    color: var(--green);
    font-family: 'Share Tech Mono', monospace;
    font-size: 13px;
    padding: 6px 16px;
    cursor: pointer;
    transition: all 0.15s;
    letter-spacing: 1px;
  }

  .modal-btn:hover {
    background: rgba(0,255,65,0.1);
    box-shadow: var(--glow);
  }

  .modal-btn.danger {
    border-color: var(--red);
    color: var(--red);
  }

  .modal-btn.danger:hover {
    background: rgba(255,0,60,0.1);
    box-shadow: var(--glow-red);
  }

  /* ─── RESULT POPUP ─── */
  #result-popup {
    display: none;
    position: fixed;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    z-index: 2000;
    background: var(--panel);
    border: 2px solid var(--green);
    box-shadow: var(--glow);
    padding: 20px 30px;
    min-width: 360px;
    text-align: center;
    border-radius: 4px;
  }

  #result-popup.fail { border-color: var(--red); box-shadow: var(--glow-red); }

  #result-title {
    font-family: 'VT323', monospace;
    font-size: 32px;
    color: var(--green);
    text-shadow: var(--glow);
    letter-spacing: 4px;
    margin-bottom: 10px;
  }

  #result-popup.fail #result-title { color: var(--red); text-shadow: var(--glow-red); }

  #result-details { font-size: 13px; color: var(--white); line-height: 2; }

  /* Glitch animation */
  @keyframes glitch {
    0%  { transform: translate(0); }
    20% { transform: translate(-2px, 1px); }
    40% { transform: translate(2px, -1px); }
    60% { transform: translate(-1px, 2px); }
    80% { transform: translate(1px, -2px); }
    100%{ transform: translate(0); }
  }

  .glitch { animation: glitch 0.3s ease infinite; }

  @keyframes blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }

  .blink { animation: blink 1s step-end infinite; }

  /* Typing cursor */
  .cursor::after {
    content: '█';
    animation: blink 1s step-end infinite;
    color: var(--green);
  }

  /* Level up flash */
  @keyframes lvlup {
    0%   { box-shadow: 0 0 20px #ff00ff; border-color: #ff00ff; }
    100% { box-shadow: none; border-color: var(--green); }
  }

  .lvlup-flash { animation: lvlup 1s ease-out; }

  /* Scrollbar styling */
  ::-webkit-scrollbar { width: 4px; }
  ::-webkit-scrollbar-track { background: transparent; }
  ::-webkit-scrollbar-thumb { background: var(--green-dim); border-radius: 2px; }

  /* Detection warning flash */
  @keyframes detect-flash {
    0%, 100% { background: var(--panel); }
    50%       { background: rgba(255,0,60,0.15); }
  }

  .detect-flash { animation: detect-flash 0.5s ease 3; }

  /* Progress bar for hacks */
  .prog-bar-wrap {
    height: 4px;

{
  "name": "canvas-tracker",
  "version": "1.0.0",
  "description": "Canvas grade and assignment tracker",
  "main": "main.js",
  "scripts": {
    "start": "node proxy.js",
    "electron": "electron .",
    "build": "electron-builder"
  },
  "dependencies": {},
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  },
  "engines": {
    "node": ">=18"
  },
  "build": {
    "appId": "com.canvastracker.app",
    "productName": "Canvas Tracker",
    "asar": false,
    "files": [
      "main.js",
      "proxy.js",
      "canvas-tracker.html",
      "package.json"
    ],
    "directories": {
      "output": "dist"
    },
    "mac": {
      "category": "public.app-category.education"
    },
    "win": {
      "target": "nsis"
    }
  }
}
